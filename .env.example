# ─────────────────────────────────────────────
# Policy Radar 환경변수 목록
# 이 파일을 복사해서 .env.local 로 이름 바꾼 후
# 실제 값을 채워 넣으세요. (.env.local은 절대 git에 올리지 마세요!)
# ─────────────────────────────────────────────

# 1. Supabase 프로젝트 URL
#    Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# 2. Supabase anon key
#    Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 3. 사이트 URL
#    배포 환경에서는 실제 서비스 도메인으로 변경
NEXT_PUBLIC_SITE_URL=https://policyradar.co.kr

# 4. Google OAuth 설정
#    Supabase Dashboard → Authentication → Providers → Google
#    Google Cloud Console의 Authorized Redirect URL에는 아래 URL을 추가해야 합니다.
#    https://your-project-ref.supabase.co/auth/v1/callback

# 5. Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
