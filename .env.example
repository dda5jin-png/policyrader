# ─────────────────────────────────────────────
# Policy Radar 환경변수 목록
# 이 파일을 복사해서 .env.local 로 이름 바꾼 후
# 실제 값을 채워 넣으세요. (.env.local은 절대 git에 올리지 마세요!)
# ─────────────────────────────────────────────

# 1. PostgreSQL DB 연결 주소
#    Vercel Postgres 또는 Supabase 무료 플랜에서 발급
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 2. Google OAuth 클라이언트 정보
#    Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 3. Better-Auth 서명 비밀키
#    터미널에서 생성: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here

# 4. Gemini API Key
#    https://aistudio.google.com/ 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# 5. 사이트 URL (Vercel 배포 후 최종 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=https://policyrader.com
